{
  "name": "worker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "lint": "eslint --config ../../eslint.config.bottomlessmargaritas.js .",
    "lint:fix": "eslint --config ../../eslint.config.bottomlessmargaritas.js . --fix",
    "format": "prettier --config ../../prettier.config.bottomlessmargaritas.mjs --write .",
    "format:check": "prettier --config ../../prettier.config.bottomlessmargaritas.mjs --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@aws-sdk/client-s3": "^3.616.0",
    "@extractus/article-extractor": "^8.0.20",
    "@google-cloud/secret-manager": "^6.1.1",
    "@research/common": "workspace:*",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^13.1.3",
    "voyageai": "^0.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20.14.10",
    "@types/pdf-parse": "^1.1.4",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.2",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3"
  }
}

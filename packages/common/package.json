{
  "name": "@research/common",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --dts",
    "dev": "tsup src/index.ts --dts --watch",
    "lint": "eslint --config ../../eslint.config.bottomlessmargaritas.js .",
    "lint:fix": "eslint --config ../../eslint.config.bottomlessmargaritas.js . --fix",
    "format": "prettier --config ../../prettier.config.bottomlessmargaritas.js --write .",
    "format:check": "prettier --config ../../prettier.config.bottomlessmargaritas.js --check ."
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.1"
  }
}

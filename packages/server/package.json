{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate -m migrations up",
    "lint": "eslint --config ../../eslint.config.bottomlessmargaritas.js .",
    "lint:fix": "eslint --config ../../eslint.config.bottomlessmargaritas.js . --fix",
    "format": "prettier --config ../../prettier.config.bottomlessmargaritas.mjs --write .",
    "format:check": "prettier --config ../../prettier.config.bottomlessmargaritas.mjs --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@aws-sdk/client-s3": "^3.616.0",
    "@aws-sdk/s3-request-presigner": "^3.616.0",
    "@research/common": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "node-pg-migrate": "^7.5.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^10.0.0",
    "voyageai": "^0.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.2",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3"
  }
}
